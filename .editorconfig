# EditorConfig - https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml,json,html,css}]
indent_size = 2

[*.tex]
indent_size = 2
indent_style = space

[*.cls]
indent_size = 2

[Makefile]
indent_style = tab

[*.{sh,bash,ps1}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
